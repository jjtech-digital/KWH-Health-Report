# Copy to .env and fill in values (cp .env.example .env)

# Auth
KWH_HEALTH_REPORT_PASSWORD=
CRON_SECRET=

# Commercetools
CT_PROJECT_KEY=
CT_CLIENT_ID=
CT_CLIENT_SECRET=
CT_AUTH_URL=
CT_API_URL=

# Humio
HUMIO_API_TOKEN=
HUMIO_REPOSITORY=kitchenwarehouse_view
HUMIO_BASE_URL=https://cloud.humio.com
HUMIO_ENVIRONMENT_FILTER=environment = production

# Datadog (AP1)
DATADOG_API_KEY=
DATADOG_APPLICATION_KEY=
DATADOG_BASE_URL=https://ap1.datadoghq.com
DATADOG_RUM_QUERY=@type:view env:prod
# DATADOG_RUM_APPLICATION_ID is not used in RUM filters (breaks queries when appended)

# Redis (required — sole cache layer)
REDIS_HOST=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=19947
REDIS_TLS=false
# Set REDIS_TLS=true only if your provider requires TLS (or use rediss:// REDIS_URL)

# Metrics refresh timeouts (ms)
METRICS_CT_TIMEOUT_MS=300000
METRICS_CT_FTB_TIMEOUT_MS=600000
METRICS_HUMIO_TIMEOUT_MS=1200000
METRICS_INVOCATION_BUDGET_MS=270000

# Commercetools batching / concurrency
CT_EMAIL_BATCH_SIZE=5
CT_EMAIL_BATCH_GAP_MS=500
CT_BATCH_SIZE=15
CT_BATCH_GAP_MS=1000
CT_MAX_CONCURRENT_JOBS=4
CT_FETCH_TIMEOUT_MS=30000
CT_FTB_FULL_WEEK_THRESHOLD=400
